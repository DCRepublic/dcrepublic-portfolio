{
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "plugins": ["prettier-plugin-tailwindcss" ],
  "tailwindStylesheet": "app/globals.css",
  "tailwindFunctions": ["cn", "cva"],
  "overrides": [
    {
      "files": ["*.md", "*.mdx"],
      "options": {
        "proseWrap": "always",
          "printWidth": 80
      }
    }
  ]
}
